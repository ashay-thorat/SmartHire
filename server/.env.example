# Database
NEON_DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# AI
GROQ_API_KEY=gsk_your_groq_api_key

# Firebase Admin (required for Google OAuth)
# Minimum: just the project ID (uses public key verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Production: full service account JSON as a single line (optional, overrides projectId)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
